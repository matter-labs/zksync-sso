{
  "name": "demo-app",
  "tags": ["type:app"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "commands": [
          {
            "command": "pnpm nx dev auth-server",
            "prefix": "Auth-Server:"
          },

          {
            "command": "PORT=3005 nuxt dev",
            "prefix": "Demo-App:"
          }
        ]
      },
      "dependsOn": ["deploy-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "commands": [
          {
            "command": "pnpm nuxt generate"
          }
        ]
      },
      "dependsOn": ["deploy-contracts"]
    },
    "build-contracts": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "FOUNDRY_LOG=trace forge build smart-contracts/ --root . --zksync"
      }
    },
    "build-sso-contracts": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/contracts",
        "command": "forge build"
      }
    },
    "deploy-contracts": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "echo '{\"deployedTo\":\"0x0000000000000000000000000000000000000000\"}' > forge-output-paymaster.json && echo '{\"deployedTo\":\"0x0000000000000000000000000000000000000000\"}' > forge-output-erc1271.json && echo 'Created stub contract JSONs for SDK build'"
      },
      "dependsOn": ["setup-local-dev"]
    },
    "setup-local-dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "../../scripts/setup-local-dev.sh"
      },
      "dependsOn": ["build-sso-contracts"]
    },
    "build:local": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "pnpm nuxt generate --envName local"
      },
      "dependsOn": ["^build"]
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "commands": [
          {
            "command": "pnpm nx preview auth-server",
            "prefix": "Auth-Server:"
          },
          {
            "command": "PORT=3005 pnpm nuxt preview",
            "prefix": "Demo-App:"
          }
        ]
      },
      "dependsOn": ["build:local"]
    },
    "dev-all": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "commands": [
          {
            "command": "pnpm nx dev:with-api auth-server",
            "prefix": "Auth-Server:"
          },
          {
            "command": "PORT=3005 pnpm run dev",
            "prefix": "Demo-App:"
          }
        ]
      },
      "dependsOn": ["build:local"]
    },
    "e2e:guardian": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "PW_TEST_HTML_REPORT_OPEN=never playwright test tests/guardian.spec.ts --config=playwright.config.sdk.ts"
      },
      "dependsOn": ["e2e:setup"]
    },
    "e2e:demo-only": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "PW_TEST_HTML_REPORT_OPEN=never playwright test --config=playwright.config.ts"
      },
      "dependsOn": ["e2e:setup"]
    },
    "e2e:setup": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "commands": [
          {
            "command": "pnpm nx run sdk:build --skip-nx-cache",
            "prefix": "Rebuild-SDK:"
          },
          {
            "command": "cd ../../packages/auth-server && pnpm nuxt build"
          },
          {
            "command": "pnpm nuxt build"
          },
          {
            "command": "pnpm exec playwright install chromium"
          }
        ]
      },
      "dependsOn": ["deploy-contracts"]
    },
    "dev:app": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "PORT=3005 pnpm run dev"
      }
    },
    "redeploy-and-sync": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "commands": [
          {
            "command": "../../scripts/setup-local-dev.sh",
            "prefix": "Setup-Local:"
          },
          {
            "command": "pnpm nx run demo-app:deploy-contracts",
            "prefix": "Stub-SDK:"
          }
        ]
      }
    },
    "e2e:no-deploy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "./scripts/run-e2e.sh"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "./scripts/run-e2e.sh"
      },
      "dependsOn": ["e2e:setup"]
    },
    "e2e:sdk:demo-only": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "commands": [
          {
            "command": "cd ../.. && ( cd examples/demo-app && PORT=3005 pnpm nuxt preview > /tmp/demo-app.log 2>&1 & echo $! > /tmp/demo-app.pid ) && sleep 5",
            "prefix": "Start-Demo:"
          },
          {
            "command": "playwright test --config=playwright.config.sdk.ts",
            "prefix": "Tests:"
          },
          {
            "command": "kill $(cat /tmp/demo-app.pid) 2>/dev/null || true",
            "prefix": "Cleanup:"
          }
        ]
      }
    },
    "ci": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "PW_TEST_HTML_REPORT_OPEN=never playwright test --config=playwright.config.sdk.ts --reporter=list"
      },
      "dependsOn": ["e2e:setup"]
    },
    "e2e:debug": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "playwright test --ui"
      },
      "dependsOn": ["e2e:setup"]
    },
    "show-report": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "examples/demo-app",
        "command": "playwright show-report"
      }
    }
  }
}
