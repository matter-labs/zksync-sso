# Server Configuration
PORT=3004

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3000

# Deployer Configuration (Private key with funds for deployment gas)
# For local development, use the Anvil rich account:
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Blockchain Configuration
RPC_URL=http://127.0.0.1:5050

# ===================================================================
# Supported Chains Configuration (REQUIRED)
# ===================================================================
# Define chains using numbered variables: CHAIN_1_*, CHAIN_2_*, etc.
# The system will automatically discover all chains starting from CHAIN_1.
#
# Required per chain:
#   CHAIN_N_ID              - Chain ID (positive integer)
#   CHAIN_N_RPC_URL         - RPC endpoint URL (optional in Prividium mode)
#
# Optional per chain:
#   CHAIN_N_BASE_TOKEN_DECIMALS - Native token decimals (defaults to 18)
#
# ===================================================================
CHAIN_1_ID=6565
CHAIN_1_RPC_URL=http://localhost:5050

# Rate Limiting Configuration
RATE_LIMIT_DEPLOY_MAX=20
RATE_LIMIT_DEPLOY_WINDOW_MS=3600000 # 1 hour

# Contract Addresses (OPTIONAL - will fall back to src/contracts.json if not provided)
# You can provide these via environment variables OR update src/contracts.json
# To deploy contracts, run: pnpm nx run demo-app:deploy-contracts-erc4337
# FACTORY_ADDRESS=0x...
# EOA_VALIDATOR_ADDRESS=0x...
# WEBAUTHN_VALIDATOR_ADDRESS=0x...
# SESSION_VALIDATOR_ADDRESS=0x...

# Prividium Mode Configuration
PRIVIDIUM_MODE=true
PRIVIDIUM_API_URL=http://localhost:8000
PRIVIDIUM_ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
PRIVIDIUM_TEMPLATE_KEY=sso-smart-account
SSO_AUTH_SERVER_BASE_URL=http://localhost:3002
